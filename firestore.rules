// ── FIRESTORE SECURITY RULES ──────────────────────────────────────────────────
// Copy this ENTIRE file content into:
// Firebase Console → Firestore Database → Rules tab → Replace → Publish

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users collection ────────────────────────────────────────────────────
    // Users can only read/write their OWN document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Progress sub-collection (done, grasp, notes, time per topic)
      match /progress/{topicId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Productivity sub-collection (daily stats)
      match /productivity/{date} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Access Keys collection ───────────────────────────────────────────────
    // Anyone logged in can READ a key (to check if it exists)
    // Anyone logged in can UPDATE a key (to mark it as used with their uid)
    // Only admin (your uid) can CREATE or DELETE keys
    // Replace ADMIN_UID_HERE with your actual Firebase UID
    match /accessKeys/{keyId} {
      allow read:   if request.auth != null;
      allow update: if request.auth != null
                    && request.resource.data.usedBy == request.auth.uid
                    && resource.data.usedBy == null; // can only claim unclaimed key
      allow create, delete: if request.auth != null
                            && request.auth.uid == 'ADMIN_UID_HERE'; // ← replace with YOUR uid
    }

  }
}
